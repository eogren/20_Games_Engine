# Matches the Allman / 4-space style already in src/.
# Run `cpp/format.sh` to check, `cpp/format.sh --write` to apply.
#
# Two YAML documents below: one for C++ (.h, .cpp), one for Objective-C++ (.mm).
# Both share the same settings; clang-format requires an explicit ObjC stanza
# to format .mm without the "does not support Objective-C" warning.

---
Language: Cpp
BasedOnStyle: LLVM
Standard: c++20

ColumnLimit: 120
IndentWidth: 4
TabWidth: 4
UseTab: Never
ContinuationIndentWidth: 4

BreakBeforeBraces: Allman
NamespaceIndentation: All

# `public:` / `private:` sit flush with the class keyword's column.
AccessModifierOffset: -4

# `T* p` and `T& r` — type-attached pointers and refs.
PointerAlignment: Left
DerivePointerAlignment: false

AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: WithoutElse
AllowShortBlocksOnASingleLine: Empty
AllowShortCaseLabelsOnASingleLine: false
AllowShortLoopsOnASingleLine: false

# Includes: existing files use a deliberate framework-first / local-after order.
SortIncludes: false
IncludeBlocks: Preserve

AlignAfterOpenBracket: Align
AlignTrailingComments: true
SpaceAfterCStyleCast: false
KeepEmptyLinesAtTheStartOfBlocks: false
MaxEmptyLinesToKeep: 1
PenaltyBreakString: 1000

---
Language: ObjC
BasedOnStyle: LLVM
Standard: c++20

ColumnLimit: 120
IndentWidth: 4
TabWidth: 4
UseTab: Never
ContinuationIndentWidth: 4

BreakBeforeBraces: Allman
NamespaceIndentation: All
AccessModifierOffset: -4
PointerAlignment: Left
DerivePointerAlignment: false

AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: WithoutElse
AllowShortBlocksOnASingleLine: Empty
AllowShortCaseLabelsOnASingleLine: false
AllowShortLoopsOnASingleLine: false

SortIncludes: false
IncludeBlocks: Preserve

AlignAfterOpenBracket: Align
AlignTrailingComments: true
SpaceAfterCStyleCast: false
KeepEmptyLinesAtTheStartOfBlocks: false
MaxEmptyLinesToKeep: 1
PenaltyBreakString: 1000

# Preserve colon-aligned multi-line message sends (Cocoa convention).
ObjCBlockIndentWidth: 4
ObjCSpaceAfterProperty: false
ObjCSpaceBeforeProtocolList: true
ObjCBreakBeforeNestedBlockParam: true
...

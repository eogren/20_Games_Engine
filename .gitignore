# macOS
.DS_Store

# CMake / Ninja build dirs.
build/
build-*/
cmake-build-*/

# clangd: mirrored from build/debug/ by build.ps1 for tools that don't read .clangd
compile_commands.json
# clangd's on-disk index
.cache/

# Xcode (cpp/ still uses the Xcode generator on macOS)
DerivedData/
xcuserdata/
*.xcuserstate
*.xcworkspace/xcuserdata/

# JetBrains IDEs (CLion / IntelliJ per-user project state)
.idea/

# Credentials
.netrc

# Claude Code (per-user settings and local agent scratch, not shared)
.claude/settings.local.json
.claude/worktrees/

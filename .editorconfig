# Pins charset/EOL/indent outside .clang-format's reach (CMake, YAML,
# JSON, PowerShell, Slang). .gitattributes already forces LF in the
# index; this is the editor-side counterpart.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.md]
# Two trailing spaces are a hard line break in Markdown — keep them.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

# Vulkan struct idioms suppressed in this subtree only. The root config
# keeps these checks on for the rest of the codebase — they're good
# general bug-catchers, just hostile to the way Vulkan structs are used.
#
#   - clang-diagnostic-missing-designated-field-initializers: Vulkan
#     structs are designated-initialized with only the fields we care
#     about; the rest value-initialize to zero, which is exactly the
#     intent. MSVC doesn't warn on this either.
#   - bugprone-invalid-enum-default-initialization: `VkFoo s{}` is the
#     idiom to zero-init before a `vkGet*` fills it. Many Vulkan flag-
#     bit enums (VkSurfaceTransformFlagBitsKHR, etc.) have no zero-value
#     enumerator, so the check flags every such {}-init even though the
#     value is immediately overwritten by the driver.

InheritParentConfig: true
Checks: >
  -clang-diagnostic-missing-designated-field-initializers,
  -bugprone-invalid-enum-default-initialization
